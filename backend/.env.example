# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (Neon Cloud PostgreSQL)
# Replace with your connection string. Make sure ?sslmode=require is present.
DATABASE_URL="postgresql://neondb_owner:<password>@<neon-hostname>/neondb?sslmode=require"

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key

# Email Configuration (Nodemailer - Optional, falls back to Ethereal Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM="Upcycle App" <noreply@upcycle.edu>
